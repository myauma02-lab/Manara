// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS / ADMIN ──────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  role          Role      @default(CONTRIBUTOR)
  avatar        String?
  bio           String?
  isActive      Boolean   @default(true)
  refreshToken  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  articles      Article[]
  researchPapers ResearchPaper[]

  publications  Publication[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  CONTRIBUTOR
}

// ─── FOUNDERS / MEMBERS ─────────────────────────────────────────
model Founder {
  id          String   @id @default(uuid())
  name        String
  slug      String?  @unique
  role        String
  bio         String? @db.Text
  photo       String?
  photoPublicId String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  researchInterests String[]
  institution       String?
  socialLinks Json?    // { instagram, twitter, linkedin }

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("founders")
}

// ─── ARTICLES ───────────────────────────────────────────────────
model Article {
  id            String          @id @default(uuid())
  title         String
  slug          String          @unique
  excerpt       String?
  content       String          @db.Text
  coverImage    String?
  coverPublicId String?
  status        ContentStatus   @default(DRAFT)
  isFeatured    Boolean         @default(false)
  publishedAt   DateTime?
  readTime      Int?            // minutes
  viewCount     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  authorId      String
  author        User            @relation(fields: [authorId], references: [id])
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id])
  tags          ArticleTag[]
  mediaType     MediaType       @default(JOURNAL)

  @@map("articles")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  createdAt   DateTime  @default(now())

  articles    Article[]
  researchPapers ResearchPaper[]

  publications  Publication[]

  @@map("categories")
}

model Tag {
  id       String       @id @default(uuid())
  name     String       @unique
  slug     String       @unique
  articles ArticleTag[]
  publications  PublicationTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  JOURNAL
  VIDEO
  PODCAST
  NEWSLETTER
  FORUM
  PAPER
}

// ─── PROJECTS / PROGRAMS ────────────────────────────────────────
model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?       @db.Text
  coverImage  String?
  status      ProjectStatus @default(UPCOMING)
  category    String?       // "Kebijakan Publik", "Lingkungan", dll
  tags        String[]
  startDate   DateTime?
  endDate     DateTime?
  progress    Int           @default(0)    // 0-100 persen
  isFeatured  Boolean       @default(false)
  isPublic    Boolean       @default(true)

  // Tim pengerjaan
  teamMembers String[]      // nama-nama anggota tim

  // Output
  outputs     String[]      // deliverables / hasil proyek

  // Milestones
  milestones  Json?         // [{title, date, done}]

  // Links
  reportUrl   String?       // link laporan final
  dataUrl     String?       // link dataset
  relatedPubs String[]      // slug publikasi terkait

  // Meta
  client      String?       // klien / mitra
  budget      String?       // budget range (opsional, bisa di-hide)
  location    String?       // lokasi penelitian

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("projects")
}

enum ProjectStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

// ─── RESEARCH PAPERS ────────────────────────────────────────────
model ResearchPaper {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  abstract      String        @db.Text
  authors       String[]
  pdfUrl        String?
  pdfPublicId   String?
  coverImage    String?
  volume        String?
  issue         String?
  year          Int?
  doi           String?
  keywords      String[]
  downloadCount Int           @default(0)
  status        ContentStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  uploadedById  String
  uploadedBy    User          @relation(fields: [uploadedById], references: [id])
  categoryId    String?
  category      Category?     @relation(fields: [categoryId], references: [id])

  @@map("research_papers")
}

// ─── NEWSLETTER ─────────────────────────────────────────────────
model NewsletterSubscriber {
  id          String              @id @default(cuid())
  email       String              @unique
  name        String?
  status      SubscriberStatus    @default(ACTIVE)
  confirmedAt DateTime?
  createdAt   DateTime            @default(now())

  @@map("newsletter_subscribers")
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

// ─── MANAPEOPLE RECRUITMENT ─────────────────────────────────────
model Recruitment {
  id              String            @id @default(uuid())
  batchName       String
  description     String?
  isOpen          Boolean           @default(true)
  openDate        DateTime?
  closeDate       DateTime?
  positions       Json              // array of position objects
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  applications    Application[]

  @@map("recruitments")
}

model Application {
  id              String            @id @default(uuid())
  recruitmentId   String
  recruitment     Recruitment       @relation(fields: [recruitmentId], references: [id])
  fullName        String
  email           String
  phone           String?
  position        String
  motivation      String            @db.Text
  cvUrl           String?
  portfolioUrl    String?
  portfolioLink   String?
  status          ApplicationStatus @default(PENDING)
  adminNotes      String?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

// ─── SITE SETTINGS ──────────────────────────────────────────────
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── MEDIA / IMAGES ─────────────────────────────────────────────
model MediaFile {
  id          String   @id @default(uuid())
  filename    String
  url         String
  publicId    String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  alt         String?
  folder      String?
  createdAt   DateTime @default(now())

  @@map("media_files")
}

// ─── ENUM BARU ───────────────────────────────────────────

enum PublicationType {
  ARTICLE
  PAPER
  JOURNAL
}

enum ArticleSubtype {
  OPINION
  ESSAY
  ANALYSIS
  COMMENTARY
  OTHER
}

enum PaperSubtype {
  POLICY_PAPER
  WORKING_PAPER
  POLICY_BRIEF
  WHITE_PAPER
  RESEARCH_NOTE
}

// ─── MODEL PUBLICATION (menggantikan articles + research) ─

model Publication {
  id          String          @id @default(cuid())
  type        PublicationType
  slug        String          @unique

  // Field umum
  title       String
  excerpt     String?         @db.Text
  content     String?         @db.Text
  abstract    String?         @db.Text
  coverImage  String?
  status      ContentStatus   @default(DRAFT)
  isFeatured  Boolean         @default(false)
  viewCount   Int             @default(0)
  publishedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relasi
  authorId    String
  author      User            @relation(fields: [authorId], references: [id])
  categoryId  String?
  category    Category?       @relation(fields: [categoryId], references: [id])
  tags        PublicationTag[]

  // Field ARTICLE
  articleSubtype  ArticleSubtype?

  // Field PAPER & JOURNAL (shared)
  paperSubtype    PaperSubtype?
  authors         String[]
  keywords        String[]
  pdfUrl          String?
  downloadCount   Int             @default(0)
  institutions    String[]

  // Field JOURNAL only
  volume      Int?
  issue       Int?
  year        Int?
  doi         String?
  reviewers   String[]
  citations   String[]
  issn        String?

  @@map("publications")
}

model PublicationTag {
  id            String      @id @default(cuid())
  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id])

  @@unique([publicationId, tagId])
  @@map("publication_tags")
}

model Fellow {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  title       String?  // gelar akademik, misal: "S.T., M.T., Ph.D."
  position    String?  // jabatan, misal: "Peneliti Senior"
  expertise   String[] // bidang keahlian
  institution String?  // afiliasi
  bio         String?  @db.Text
  photo       String?
  email       String?
  socialLinks Json?    // { linkedin, twitter, instagram, website }
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fellows")
}

// ─── ENUM ────────────────────────────────────────────
enum InfoType {
  NEWS
  AWARD
  MAGAZINE
  AGENDA
}

enum InfoStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── MODEL ───────────────────────────────────────────
model InfoItem {
  id          String     @id @default(cuid())
  type        InfoType
  status      InfoStatus @default(DRAFT)
  title       String
  slug        String     @unique
  excerpt     String?    @db.Text
  content     String?    @db.Text
  coverImage  String?
  fileUrl     String?    // untuk magazine (PDF)
  isFeatured  Boolean    @default(false)
  publishedAt DateTime?

  // NEWS
  source      String?    // sumber berita
  externalUrl String?    // link berita eksternal

  // AWARD
  awardGiver  String?    // pemberi penghargaan
  awardYear   Int?
  awardCategory String?

  // MAGAZINE
  issueNumber String?    // "Vol. 1 No. 2"
  issueYear   Int?

  // AGENDA
  eventDate   DateTime?
  eventEndDate DateTime?
  eventLocation String?
  eventType   String?    // "Seminar", "Workshop", "Forum"
  isHighlight Boolean    @default(false)

  // Meta
  tags        String[]
  viewCount   Int        @default(0)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("info_items")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  purpose   String?  @default("Umum")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}