// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS / ADMIN ──────────────────────────────────────────────
model User {
  id String @id @default(cuid())

  email    String   @unique
  password String
  name     String
  role     UserRole
  avatar   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  hrNotes      HRNote[]

  articles       Article[]       @relation("ArticleAuthor")
  researchPapers ResearchPaper[] @relation("ResearchUploader")
  publications   Publication[]   @relation("PublicationAuthor")

  @@map("users")
}

enum UserRole {
  SUPERADMIN
  SEKJEN
  PUBLIKASI_ADMIN
  PUBLIKASI_EDITOR
  PUBLIKASI_WRITER
  HR
  OPERASIONAL
  KEUANGAN
}

// ─── FINANCE ─────────────────────────────────────────
enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Transaction {
  id          String            @id @default(cuid())
  type        TransactionType
  category    String
  amount      Float
  description String
  date        DateTime
  status      TransactionStatus @default(PENDING)
  reference   String?
  attachment  String?
  notes       String?           @db.Text
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("transactions")
}

model Budget {
  id        String   @id @default(cuid())
  name      String
  category  String
  amount    Float
  spent     Float    @default(0)
  period    String // format: "2025-07" atau "2025-Q3"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("budgets")
}

// ─── HR ENHANCEMENT ──────────────────────────────────
enum EmployeeStatus {
  PROBATION
  ACTIVE
  INACTIVE
  RESIGNED
}

enum InterviewResult {
  PENDING
  PASSED
  FAILED
  RESCHEDULED
}

model Employee {
  id               String         @id @default(cuid())
  applicationId    String?        @unique
  fullName         String
  email            String         @unique
  phone            String?
  position         String
  department       String
  joinDate         DateTime
  endDate          DateTime?
  status           EmployeeStatus @default(PROBATION)
  photoUrl         String?
  address          String?
  emergencyContact String?
  notes            HRNote[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("employees")
}

model HRNote {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())

  @@map("hr_notes")
}

model InterviewSchedule {
  id              String          @id @default(cuid())
  applicationId   String
  application     Application     @relation(fields: [applicationId], references: [id])
  scheduledAt     DateTime
  durationMinutes Int             @default(60)
  location        String?
  meetLink        String?
  interviewerName String?
  notes           String?         @db.Text
  result          InterviewResult @default(PENDING)
  resultNotes     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("interview_schedules")
}

// ─── FOUNDERS / MEMBERS ─────────────────────────────────────────
model Founder {
  id            String  @id @default(uuid())
  name          String
  slug          String? @unique
  role          String
  bio           String? @db.Text
  photo         String?
  photoPublicId String?
  order         Int     @default(0)
  isActive      Boolean @default(true)

  researchInterests String[]
  institution       String?
  socialLinks       Json? // { instagram, twitter, linkedin }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("founders")
}

// ─── ARTICLES ───────────────────────────────────────────────────
model Article {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  excerpt       String?
  content       String        @db.Text
  coverImage    String?
  coverPublicId String?
  status        ContentStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  publishedAt   DateTime?
  readTime      Int? // minutes
  viewCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  authorId   String
  author     User         @relation("ArticleAuthor", fields: [authorId], references: [id])
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id])
  tags       ArticleTag[]
  mediaType  MediaType    @default(JOURNAL)

  @@map("articles")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  color       String?
  createdAt   DateTime @default(now())

  articles       Article[]
  researchPapers ResearchPaper[]

  publications Publication[]

  @@map("categories")
}

model Tag {
  id           String           @id @default(uuid())
  name         String           @unique
  slug         String           @unique
  articles     ArticleTag[]
  publications PublicationTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum MediaType {
  JOURNAL
  VIDEO
  PODCAST
  NEWSLETTER
  FORUM
  PAPER
}

// ─── PROJECTS / PROGRAMS ────────────────────────────────────────
model Project {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?       @db.Text
  coverImage  String?
  status      ProjectStatus @default(UPCOMING)
  category    String? // "Kebijakan Publik", "Lingkungan", dll
  tags        String[]
  startDate   DateTime?
  endDate     DateTime?
  progress    Int           @default(0) // 0-100 persen
  isFeatured  Boolean       @default(false)
  isPublic    Boolean       @default(true)

  // Tim pengerjaan
  teamMembers String[] // nama-nama anggota tim

  // Output
  outputs String[] // deliverables / hasil proyek

  // Milestones
  milestones Json? // [{title, date, done}]

  // Links
  reportUrl   String? // link laporan final
  dataUrl     String? // link dataset
  relatedPubs String[] // slug publikasi terkait

  // Meta
  client   String? // klien / mitra
  budget   String? // budget range (opsional, bisa di-hide)
  location String? // lokasi penelitian

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

enum ProjectStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

// ─── RESEARCH PAPERS ────────────────────────────────────────────
model ResearchPaper {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  abstract      String        @db.Text
  authors       String[]
  pdfUrl        String?
  pdfPublicId   String?
  coverImage    String?
  volume        String?
  issue         String?
  year          Int?
  doi           String?
  keywords      String[]
  downloadCount Int           @default(0)
  status        ContentStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  uploadedById String
  uploadedBy   User      @relation("ResearchUploader", fields: [uploadedById], references: [id])
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])

  @@map("research_papers")
}

// ─── NEWSLETTER ─────────────────────────────────────────────────
model NewsletterSubscriber {
  id          String           @id @default(cuid())
  email       String           @unique
  name        String?
  status      SubscriberStatus @default(ACTIVE)
  confirmedAt DateTime?
  createdAt   DateTime         @default(now())

  @@map("newsletter_subscribers")
}

enum SubscriberStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
}

// ─── SITE SETTINGS ──────────────────────────────────────────────
model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── MEDIA / IMAGES ─────────────────────────────────────────────
model MediaFile {
  id        String   @id @default(uuid())
  filename  String
  url       String
  publicId  String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  alt       String?
  folder    String?
  createdAt DateTime @default(now())

  @@map("media_files")
}

// ─── ENUM BARU ───────────────────────────────────────────

enum PublicationType {
  ARTICLE
  PAPER
  JOURNAL
}

enum ArticleSubtype {
  OPINION
  ESSAY
  ANALYSIS
  COMMENTARY
  OTHER
}

enum PaperSubtype {
  POLICY_PAPER
  WORKING_PAPER
  POLICY_BRIEF
  WHITE_PAPER
  RESEARCH_NOTE
}

// ─── MODEL PUBLICATION (menggantikan articles + research) ─

model Publication {
  id   String          @id @default(cuid())
  type PublicationType
  slug String          @unique

  // Field umum
  title       String
  excerpt     String?       @db.Text
  content     String?       @db.Text
  abstract    String?       @db.Text
  coverImage  String?
  status      ContentStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  viewCount   Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relasi
  authorId   String
  author     User             @relation("PublicationAuthor", fields: [authorId], references: [id])
  categoryId String?
  category   Category?        @relation(fields: [categoryId], references: [id])
  tags       PublicationTag[]

  // Field ARTICLE
  articleSubtype ArticleSubtype?

  // Field PAPER & JOURNAL (shared)
  paperSubtype  PaperSubtype?
  authors       String[]
  keywords      String[]
  pdfUrl        String?
  downloadCount Int           @default(0)
  institutions  String[]

  // Field JOURNAL only
  volume    Int?
  issue     Int?
  year      Int?
  doi       String?
  reviewers String[]
  citations String[]
  issn      String?

  @@map("publications")
}

model PublicationTag {
  id            String      @id @default(cuid())
  publicationId String
  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id])

  @@unique([publicationId, tagId])
  @@map("publication_tags")
}

model Fellow {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  title       String? // gelar akademik, misal: "S.T., M.T., Ph.D."
  position    String? // jabatan, misal: "Peneliti Senior"
  expertise   String[] // bidang keahlian
  institution String? // afiliasi
  bio         String?  @db.Text
  photo       String?
  email       String?
  socialLinks Json? // { linkedin, twitter, instagram, website }
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("fellows")
}

// ─── ENUM ────────────────────────────────────────────
enum InfoType {
  NEWS
  AWARD
  MAGAZINE
  AGENDA
}

enum InfoStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── MODEL ───────────────────────────────────────────
model InfoItem {
  id          String     @id @default(cuid())
  type        InfoType
  status      InfoStatus @default(DRAFT)
  title       String
  slug        String     @unique
  excerpt     String?    @db.Text
  content     String?    @db.Text
  coverImage  String?
  fileUrl     String? // untuk magazine (PDF)
  isFeatured  Boolean    @default(false)
  publishedAt DateTime?

  // NEWS
  source      String? // sumber berita
  externalUrl String? // link berita eksternal

  // AWARD
  awardGiver    String? // pemberi penghargaan
  awardYear     Int?
  awardCategory String?

  // MAGAZINE
  issueNumber String? // "Vol. 1 No. 2"
  issueYear   Int?

  // AGENDA
  eventDate     DateTime?
  eventEndDate  DateTime?
  eventLocation String?
  eventType     String? // "Seminar", "Workshop", "Forum"
  isHighlight   Boolean   @default(false)

  // Meta
  tags      String[]
  viewCount Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("info_items")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  purpose   String?  @default("Umum")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_messages")
}

// ─── WAITLIST (saat tidak ada batch) ──────────────────
model WaitlistEntry {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  interest  String? // minat/bidang yang diminati
  message   String?  @db.Text
  source    String? // dari mana tahu Manara
  createdAt DateTime @default(now())

  @@map("waitlist_entries")
}

// ─── PASTIKAN model Recruitment seperti ini ───────────
model Recruitment {
  id           String        @id @default(cuid())
  batchName    String
  description  String?       @db.Text
  isActive     Boolean       @default(false)
  startDate    DateTime?
  endDate      DateTime? // deadline pendaftaran
  positions    Position[]
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("recruitments")
}

model Position {
  id            String      @id @default(cuid())
  name          String
  description   String?     @db.Text
  requirements  String[]
  slots         Int? // kuota (null = unlimited)
  recruitmentId String
  recruitment   Recruitment @relation(fields: [recruitmentId], references: [id], onDelete: Cascade)

  @@map("positions")
}

model Application {
  id            String              @id @default(cuid())
  recruitmentId String
  recruitment   Recruitment         @relation(fields: [recruitmentId], references: [id])
  fullName      String
  email         String
  phone         String?
  position      String
  motivation    String              @db.Text
  interviews    InterviewSchedule[]
  portfolioLink String?
  cvUrl         String?
  status        ApplicationStatus   @default(PENDING)
  adminNotes    String?             @db.Text
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  ACCEPTED
  REJECTED
}
